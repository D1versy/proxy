# ============================================================
# Настройки proxy-сервера (для docker-compose / proxy_server.py)
# ============================================================

# Порт, на котором слушает прокси (по умолчанию 1111)
PROXY_PORT=1111

# Логирование запросов в stdout (true / false)
PROXY_LOG=true

# ============================================================
# Настройки для КЛИЕНТСКОГО проекта (другая машина / контейнер)
# Добавьте в .env вашего проекта, который использует прокси.
# ============================================================

# Замените <proxy-host> на IP или hostname машины с прокси.
# Примеры:
#   INSTAGRAM_PROXY=http://192.168.1.50:1111
#   INSTAGRAM_PROXY=http://proxy-server.local:1111
#   INSTAGRAM_PROXY=http://10.0.0.5:1111

INSTAGRAM_PROXY=http://<proxy-host>:1111
