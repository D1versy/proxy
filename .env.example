# ============================================================
# Proxy server settings (for docker-compose / proxy_server.py)
# ============================================================

# Port the proxy listens on (default: 1111)
PROXY_PORT=1111

# Log requests to stdout (true / false)
PROXY_LOG=true

# ============================================================
# CLIENT project settings (another machine / container)
# Add these to the .env of the project that uses the proxy.
# ============================================================

# Replace <proxy-host> with the IP or hostname of the proxy machine.
# Examples:
#   INSTAGRAM_PROXY=http://192.168.1.50:1111
#   INSTAGRAM_PROXY=http://proxy-server.local:1111
#   INSTAGRAM_PROXY=http://10.0.0.5:1111

INSTAGRAM_PROXY=http://<proxy-host>:1111
